# Binance API (créer sur binance.com > API Management)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Telegram Bot (créer via @BotFather sur Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Mode: "paper" (simulation) ou "live" (réel) — commence TOUJOURS par paper
TRADING_MODE=paper
